{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate config for k8s-gitops: auto-update Helm charts managed by FluxCD",

  "extends": [
    "config:recommended",
    "docker:enableMajor"
  ],

  "ignorePaths": [
    "**/node_modules/**",
    "**/.git/**",
    "**/flux-system/**"
  ],

  "flux": {
      "/(^|/)helmrelease.*\\.yaml$/",
      "/(^|/)helmrepository.*\\.yaml$/",
      "/(^|/)repository\\.yaml$/"
    ]
  },

  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,

  "kubernetes": {
    "managerFilePatterns": [
      "/\.yaml$/"
    ]
  },

  "labels": ["dependencies"],

  "packageRules": [
    {
      "description": "Auto-merge Patch updates safely across the entire cluster",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Auto-merge Minor updates ONLY for Workloads and Platform apps (Stateless/Safe)",
      "matchFileNames": ["workloads/**", "platform/**"],
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Manual review required for System and Datastores Minor updates (Critical Infra)",
      "matchFileNames": ["system/**", "datastores/**", "clusters/**"],
      "matchUpdateTypes": ["minor"],
      "automerge": false
    },
    {
      "description": "Major updates always require manual review and warn of breaking changes",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "⚠️ breaking"]
    }
  ],

  "timezone": "Asia/Shanghai",

  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🤖 Renovate Dependency Dashboard",

  "commitMessagePrefix": "chore(deps):",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{newVersion}}",

  "prBodyNotes": [
    "This PR was auto-generated by [Renovate Bot](https://github.com/renovatebot/renovate).",
    "Please review the changelog below before merging."
  ]
}
