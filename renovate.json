{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate config for k8s-gitops: auto-update Helm charts managed by FluxCD",

  "extends": [
    "config:recommended",
    "docker:enableMajor"
  ],

  "ignorePaths": [
    "**/node_modules/**",
    "**/.git/**",
    "**/flux-system/**"
  ],

  "flux": {
    "managerFilePatterns": [
      "/(^|/)helmrelease.*\\.yaml$/",
      "/(^|/)helmrepository.*\\.yaml$/",
      "/(^|/)repository\\.yaml$/"
    ]
  },

  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,

  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ]
  },

  "labels": ["dependencies"],

  "packageRules": [
    {
      "description": "Group System patch updates (safe, auto-merge)",
      "matchFileNames": ["system/**"],
      "matchUpdateTypes": ["patch"],
      "groupName": "system-patch",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group System & Cluster minor updates (critical infra, manual review)",
      "matchFileNames": ["system/**", "clusters/**"],
      "matchUpdateTypes": ["minor"],
      "groupName": "system-minor",
      "automerge": false
    },
    {
      "description": "Group Platform patch+minor updates (stateless, auto-merge)",
      "matchFileNames": ["platform/**"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "platform-all",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group Workloads patch+minor updates (stateless, auto-merge)",
      "matchFileNames": ["workloads/**"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "workloads-all",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group Datastores patch updates (safe, auto-merge)",
      "matchFileNames": ["datastores/**"],
      "matchUpdateTypes": ["patch"],
      "groupName": "datastores-patch",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group Datastores minor updates (critical infra, manual review)",
      "matchFileNames": ["datastores/**"],
      "matchUpdateTypes": ["minor"],
      "groupName": "datastores-minor",
      "automerge": false
    },
    {
      "description": "Major updates: individual PRs, manual review required",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "⚠️ breaking"]
    }
  ],

  "timezone": "Asia/Shanghai",

  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🤖 Renovate Dependency Dashboard",

  "commitMessagePrefix": "chore(deps):",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{newVersion}}",

  "prBodyNotes": [
    "This PR was auto-generated by [Renovate Bot](https://github.com/renovatebot/renovate).",
    "Please review the changelog below before merging."
  ]
}
